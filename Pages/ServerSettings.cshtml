@page
@model SteamCmdWebAPI.Pages.ServerSettingsModel
@{
    ViewData["Title"] = "Cài đặt Server";
}

<div class="container">
    <h1>Cài đặt Server</h1>
    
    @if (!string.IsNullOrEmpty(Model.StatusMessage))
    {
        <div class="alert @(Model.IsSuccess ? "alert-success" : "alert-danger")" role="alert">
            @Model.StatusMessage
        </div>
    }
    
    <div class="card">
        <div class="card-header">
            <h5>Cấu hình kết nối đến Server</h5>
        </div>
        <div class="card-body">
            <form method="post">
                <div class="mb-3">
                    <label asp-for="Settings.ServerAddress" class="form-label">Địa chỉ Server:</label>
                    <input asp-for="Settings.ServerAddress" class="form-control" placeholder="Ví dụ: localhost hoặc 192.168.1.100" />
                    <span asp-validation-for="Settings.ServerAddress" class="text-danger"></span>
                    <div class="form-text">Nhập địa chỉ IP hoặc hostname của server.</div>
                </div>
                
                <div class="mb-3">
                    <label asp-for="Settings.ServerPort" class="form-label">Cổng:</label>
                    <input asp-for="Settings.ServerPort" type="number" class="form-control" />
                    <span asp-validation-for="Settings.ServerPort" class="text-danger"></span>
                    <div class="form-text">Mặc định: 61188</div>
                </div>
                
                <div class="mb-3 form-check">
                    <input asp-for="Settings.EnableServerSync" type="checkbox" class="form-check-input" />
                    <label asp-for="Settings.EnableServerSync" class="form-check-label">Cho phép đồng bộ với server</label>
                </div>
                
                @if (Model.Settings.LastSyncTime.HasValue)
                {
                    <div class="mb-3">
                        <p>Lần đồng bộ cuối: @Model.Settings.LastSyncTime.Value.ToString("dd/MM/yyyy HH:mm:ss")</p>
                    </div>
                }
                
                <div class="d-flex">
                    <button type="submit" class="btn btn-primary me-2">Lưu cài đặt</button>
                    <button type="submit" asp-page-handler="TestConnection" class="btn btn-secondary me-2">Kiểm tra kết nối</button>
                    <button type="submit" asp-page-handler="TestProfiles" class="btn btn-info">Kiểm tra profile</button>
                </div>
            </form>
        </div>
    </div>
    
    <div class="mt-3">
        <a asp-page="/Index" class="btn btn-secondary">Quay lại trang chủ</a>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}